// RAS Portal — Prisma Schema
// Database: CockroachDB (PostgreSQL wire protocol)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────

enum Role {
  APPLICANT
  ATTENDEE
  ADMIN
  JUDGE
  SPONSOR
  STAFF
  SUPER_ADMIN
}

enum AppStatus {
  PENDING
  UNDER_REVIEW
  ACCEPTED
  WAITLISTED
  REJECTED
  WITHDRAWN
}

enum MealType {
  FRIDAY_DINNER
  SATURDAY_BREAKFAST
  SATURDAY_LUNCH
  SATURDAY_DINNER
  SUNDAY_BREAKFAST
  SUNDAY_LUNCH
}

enum EventType {
  GENERAL
  WORKSHOP
  MEAL
  JUDGING
  CEREMONY
  SPONSOR
}

enum SponsorTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ─── AUTH MODELS (NextAuth) ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CORE USER MODEL ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(APPLICANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  application   Application?
  judgingScores JudgingScore[]
  scanEvents    ScanEvent[]
  sponsorProfile Sponsor?
}

// ─── APPLICATION ──────────────────────────────────────────────────────────

model Application {
  id     String    @id @default(cuid())
  userId String    @unique
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status AppStatus @default(PENDING)

  // Personal Info
  firstName      String
  lastName       String
  phone          String?
  university     String
  graduationYear Int
  major          String
  country        String?

  // Hackathon Info
  experience     String  // beginner | intermediate | advanced
  teamPreference String  // solo | have-team | looking
  projectIdea    String? 
  dietaryRestrictions String?
  tShirtSize     String? // XS S M L XL XXL
  needsHardware  Boolean @default(false)

  // Social Links
  githubUrl     String?
  linkedinUrl   String?
  portfolioUrl  String?
  resumeUrl     String? // S3 presigned URL

  // QR / Check-in
  qrCode      String?   @unique @default(cuid())
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?

  // Admin fields
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  adminNotes  String?   

  // Relations
  mealTickets MealTicket[]
}

// ─── MEAL TICKETS ─────────────────────────────────────────────────────────

model MealTicket {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  mealType      MealType
  redeemedAt    DateTime?
  redeemedBy    String?     // staff user ID

  @@unique([applicationId, mealType])
}

// ─── PROJECTS & JUDGING ───────────────────────────────────────────────────

model Track {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  prize       String?
  projects    Project[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   
  tableNumber Int?
  trackId     String?
  track       Track?   @relation(fields: [trackId], references: [id])
  teamMembers String[] // user IDs (denormalized for simplicity)
  repoUrl     String?
  demoUrl     String?
  devpostUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scores JudgingScore[]
}

model JudgingScore {
  id        String  @id @default(cuid())
  judgeId   String
  judge     User    @relation(fields: [judgeId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Scoring rubric (1-10 each)
  innovation   Int
  technical    Int
  presentation Int
  impact       Int

  // Computed: stored for fast queries
  overall Float

  notes     String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([judgeId, projectId])
}

// ─── SCHEDULE ─────────────────────────────────────────────────────────────

model ScheduleEvent {
  id          String    @id @default(cuid())
  title       String
  description String?   
  location    String?
  startTime   DateTime
  endTime     DateTime
  type        EventType @default(GENERAL)
  isPublic    Boolean   @default(true)
  color       String?   // hex override for calendar
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── SPONSORS ─────────────────────────────────────────────────────────────

model Sponsor {
  id          String      @id @default(cuid())
  userId      String      @unique
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  tier        SponsorTier @default(BRONZE)
  logoUrl     String?
  website     String?
  description String?     
  contactName String?
  prizeTrack  String?     // which track they sponsor
  createdAt   DateTime    @default(now())
}

// ─── SCAN EVENTS (audit log) ──────────────────────────────────────────────

model ScanEvent {
  id        String   @id @default(cuid())
  staffId   String
  staff     User     @relation(fields: [staffId], references: [id])
  qrCode    String
  action    String   // CHECK_IN | MEAL_FRIDAY_DINNER | MEAL_SATURDAY_BREAKFAST | etc.
  success   Boolean
  message   String?
  createdAt DateTime @default(now())
}
