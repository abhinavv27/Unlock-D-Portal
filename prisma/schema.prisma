// Universal Event Engine — Database Schema
// Database: PostgreSQL / Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── MODELS ───────────────────────────────────────────────────────────────

model User {
  id           Int          @id @default(autoincrement())
  username     String       @unique
  passwordHash String       @map("password_hash")
  systemRole   String       @map("system_role") // 'ADMIN' or 'JUDGE'
  evaluations  Evaluation[]

  @@map("users")
}

model Event {
  id                 Int            @id @default(autoincrement())
  slug               String         @unique
  name               String
  eventType          String         @map("event_type") // e.g., 'PROGRESSIVE_HACKATHON', 'CTF'
  config             Json // JSONB: stores rules, stages, grading rubrics, etc.
  currentGlobalRound Int            @default(1) @map("current_global_round")
  isActive           Boolean        @default(true) @map("is_active")
  registrations      Registration[]

  @@map("events")
}

model Registration {
  id               String       @id @default(uuid()) @db.Uuid
  eventId          Int          @map("event_id")
  event            Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  unstopTeamId     String       @map("unstop_team_id")
  teamName         String       @map("team_name")
  teamPasscodeHash String       @map("team_passcode_hash")
  memberDetails    Json?        @map("member_details")
  progressState    Json         @default("{}") @map("progress_state") // JSONB: tracks stage, points, log, dynamic status
  totalScore       Float        @default(0.0) @map("total_score")
  registeredAt     DateTime     @default(now()) @map("registered_at")
  submissions      Submission[]
  sessions         Session[]

  @@unique([eventId, unstopTeamId])
  @@map("registrations")
}

model Submission {
  id              Int          @id @default(autoincrement())
  registrationId  String       @map("registration_id") @db.Uuid
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  roundNumber     Int          @map("round_number")
  taskId          String       @map("task_id")
  rejectionReason String?      @map("rejection_reason")
  payload         Json // JSONB: dynamic submission payload (e.g. GitHub URL, CTF flag submission)
  status          String       @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  averageScore    Float?       @map("average_score")
  submittedAt     DateTime     @default(now()) @map("submitted_at")
  evaluations     Evaluation[]

  @@map("submissions")
}

model Evaluation {
  id             Int        @id @default(autoincrement())
  submissionId   Int        @map("submission_id")
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  judgeId        Int        @map("judge_id")
  judge          User       @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  scoreBreakdown Json       @map("score_breakdown") // JSONB: rubric scores (e.g. {"innovation": 8, "code": 9})
  totalScore     Int        @map("total_score")
  feedback       String
  gradedAt       DateTime   @default(now()) @map("graded_at")

  @@unique([submissionId, judgeId])
  @@map("evaluations")
}

model Session {
  id             String       @id @default(uuid()) @db.Uuid
  registrationId String       @map("registration_id") @db.Uuid
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("sessions")
}
